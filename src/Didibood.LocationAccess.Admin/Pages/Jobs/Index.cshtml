@page
@model Didibood.LocationAccess.Admin.Pages.Jobs.IndexModel
@{
    ViewData["Title"] = "مانیتور کارها";
    ViewData["ActivePage"] = "Jobs";
}

<div class="d-flex justify-content-between align-items-center mb-4" dir="rtl">
    <div>
        <div class="page-title">مانیتور کارهای Crawl</div>
        <small class="text-muted">تاریخچه اجرای تمام کارها — صفحه @Model.CurrentPage از @Model.TotalPages</small>
    </div>
    <div class="d-flex gap-2 align-items-center">
        <span class="badge bg-primary" id="jobs-refresh-badge">بروزرسانی خودکار</span>
        <a asp-page="/Jobs/Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-clockwise"></i>
        </a>
    </div>
</div>

<!-- Status filter -->
<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="d-flex flex-wrap gap-2 align-items-center" dir="rtl">
            <label class="form-label mb-0 small fw-semibold">فیلتر وضعیت:</label>
            @foreach (var status in new[] { "running", "completed", "failed", "cancelled" })
            {
                <a asp-page="/Jobs/Index"
                   asp-route-statusFilter="@status"
                   asp-route-page="1"
                   class="badge text-decoration-none badge-@status @(Model.StatusFilter == status ? "opacity-100" : "opacity-50")"
                   style="font-size:.8rem;padding:.4em .7em">
                    @status
                </a>
            }
            @if (!string.IsNullOrEmpty(Model.StatusFilter))
            {
                <a asp-page="/Jobs/Index" class="btn btn-link btn-sm text-muted p-0">× پاک کردن فیلتر</a>
            }
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div id="jobs-table-wrapper">
            @await Html.PartialAsync("_JobsTablePartial", Model)
        </div>
    </div>
</div>

<!-- Pagination -->
@if (Model.TotalPages > 1)
{
    <nav class="mt-3 d-flex justify-content-center" dir="rtl">
        <ul class="pagination pagination-sm">
            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-page="/Jobs/Index"
                   asp-route-page="@(Model.CurrentPage - 1)"
                   asp-route-statusFilter="@Model.StatusFilter">قبلی</a>
            </li>
            @for (int p = Math.Max(1, Model.CurrentPage - 2); p <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); p++)
            {
                <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-page="/Jobs/Index"
                       asp-route-page="@p"
                       asp-route-statusFilter="@Model.StatusFilter">@p</a>
                </li>
            }
            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-page="/Jobs/Index"
                   asp-route-page="@(Model.CurrentPage + 1)"
                   asp-route-statusFilter="@Model.StatusFilter">بعدی</a>
            </li>
        </ul>
    </nav>
}

@section Scripts {
<script>
    let pollSeconds = @(Model.HasActiveCrawl ? 3 : 5);
    const badge = document.getElementById('jobs-refresh-badge');
    const wrapper = document.getElementById('jobs-table-wrapper');

    async function pollJobs() {
        const params = new URLSearchParams(window.location.search);
        params.set('handler', 'JobsPartial');
        try {
            const r = await fetch('/Jobs/Index?' + params.toString(), {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });
            if (r.ok) wrapper.innerHTML = await r.text();
        } catch (_) {}
        pollSeconds = wrapper.querySelector('.table-primary') ? 3 : 5;
    }

    pollJobs();

    setInterval(() => {
        pollSeconds--;
        if (pollSeconds <= 0) {
            pollJobs();
        } else if (badge) {
            badge.textContent = `بروزرسانی در ${pollSeconds}s`;
        }
    }, 1000);
</script>
}
