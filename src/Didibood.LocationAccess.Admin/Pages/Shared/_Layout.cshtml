<!DOCTYPE html>
<html lang="fa-IR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — مدیریت دیدی‌بود</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        :root {
            --sidebar-bg: #1a1a2e;
            --sidebar-width: 252px;
        }
        body {
            display: flex;
            min-height: 100vh;
            background: #f4f6fb;
            font-family: 'Segoe UI', Tahoma, sans-serif;
        }
        #sidebar {
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            color: #fff;
            min-height: 100vh;
            flex-shrink: 0;
            position: fixed;
            top: 0; left: 0; z-index: 100;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }
        .sidebar-brand {
            padding: 1.2rem 1.5rem;
            font-size: 1rem;
            font-weight: 700;
            border-bottom: 1px solid rgba(255,255,255,.1);
            color: #fff;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: .5rem;
        }
        .sidebar-brand:hover { color: #fff; }
        #sidebar .nav-link {
            color: rgba(255,255,255,.72);
            padding: .52rem 1.5rem;
            display: flex;
            align-items: center;
            gap: .65rem;
            border-radius: 0;
            font-size: .9rem;
            transition: background .15s, color .15s;
        }
        #sidebar .nav-link:hover { background: rgba(255,255,255,.08); color: #fff; }
        #sidebar .nav-link.active { background: rgba(255,255,255,.13); color: #fff; border-left: 3px solid #0d6efd; }
        .nav-section-label {
            font-size: .68rem;
            text-transform: uppercase;
            letter-spacing: .09em;
            color: rgba(255,255,255,.3);
            padding: 1rem 1.5rem .3rem;
        }
        .sidebar-footer {
            margin-top: auto;
            padding: .75rem 1.5rem;
            border-top: 1px solid rgba(255,255,255,.08);
            font-size: .75rem;
            color: rgba(255,255,255,.35);
        }
        #content-wrapper {
            margin-left: var(--sidebar-width);
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
        }
        #topnav {
            background: #fff;
            border-bottom: 1px solid #e9ecef;
            height: 56px;
            display: flex;
            align-items: center;
            padding: 0 1.75rem;
            position: sticky;
            top: 0; z-index: 50;
            box-shadow: 0 1px 4px rgba(0,0,0,.06);
            gap: .75rem;
        }
        main.page-content { padding: 1.75rem; flex: 1; }
        .card { border: 0; border-radius: .5rem; box-shadow: 0 1px 4px rgba(0,0,0,.07); }
        .card:hover { box-shadow: 0 3px 12px rgba(0,0,0,.1); transition: box-shadow .2s; }
        .badge-running    { background-color: #0d6efd !important; }
        .badge-completed  { background-color: #198754 !important; }
        .badge-failed     { background-color: #dc3545 !important; }
        .badge-cancelled  { background-color: #adb5bd !important; color: #fff !important; }
        .badge-pending    { background-color: #6c757d !important; }
        .badge-stale      { background-color: #fd7e14 !important; }
        .badge-success-hl { background-color: #198754 !important; }
        table thead th { background: #f8f9fa; font-size: .82rem; font-weight: 600; text-transform: uppercase; letter-spacing: .04em; }
        .page-title { font-size: 1.3rem; font-weight: 700; margin-bottom: .2rem; }
        @@media (max-width: 768px) {
            #sidebar { width: 100%; min-height: auto; position: relative; }
            #content-wrapper { margin-left: 0; }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <nav id="sidebar">
        <a class="sidebar-brand" asp-page="/Index">
            <i class="bi bi-geo-alt-fill text-info"></i>
            دیدی‌بود Admin
        </a>

        <div class="nav-section-label">مدیریت</div>
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active" : "")" asp-page="/Index">
                    <i class="bi bi-speedometer2"></i><span>داشبورد</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Scheduler" ? "active" : "")" asp-page="/Scheduler/Index">
                    <i class="bi bi-clock-history"></i><span>زمان‌بندی Crawl</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Crawl" ? "active" : "")" asp-page="/Crawl/Index">
                    <i class="bi bi-play-circle"></i><span>Crawl دستی</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Jobs" ? "active" : "")" asp-page="/Jobs/Index">
                    <i class="bi bi-list-task"></i><span>مانیتور کارها</span>
                </a>
            </li>
        </ul>

        <div class="nav-section-label">تنظیمات</div>
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Config" ? "active" : "")" asp-page="/Config/Index">
                    <i class="bi bi-gear"></i><span>پیکربندی سیستم</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "StaticMap" ? "active" : "")" asp-page="/StaticMap/Index">
                    <i class="bi bi-map"></i><span>نقشه استاتیک</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "DataQuality" ? "active" : "")" asp-page="/DataQuality/Index">
                    <i class="bi bi-check2-circle"></i><span>کیفیت داده</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Coverage" ? "active" : "")" asp-page="/Coverage/Index">
                    <i class="bi bi-grid-3x3-gap"></i><span>مانیتور پوشش</span>
                </a>
            </li>
        </ul>

        <div class="sidebar-footer">Phase 9 — Coverage Monitor</div>
    </nav>

    <div id="content-wrapper">
        <div id="topnav">
            <span class="fw-semibold text-dark me-auto">سرویس دسترسی به موقعیت مکانی</span>
            <span class="badge bg-success d-flex align-items-center gap-1" id="health-badge" style="font-size:.75rem">
                <i class="bi bi-circle-fill" style="font-size:.5rem"></i>آنلاین
            </span>
            <span class="text-muted small">@DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm") UTC</span>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <form asp-page="/Account/Logout" method="post" class="m-0">
                    <button type="submit" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-box-arrow-right me-1"></i>خروج (@User.Identity.Name)
                    </button>
                </form>
            }
        </div>

        <main class="page-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
