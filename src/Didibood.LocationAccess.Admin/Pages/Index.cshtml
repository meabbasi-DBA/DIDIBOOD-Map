@page
@model Didibood.LocationAccess.Admin.Pages.IndexModel
@{
    ViewData["Title"] = "داشبورد";
    ViewData["ActivePage"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4" dir="rtl">
    <div>
        <div class="page-title">داشبورد مدیریت</div>
        <small class="text-muted">بروزرسانی: @Model.LastRefresh.ToString("yyyy-MM-dd HH:mm:ss") UTC</small>
    </div>
    <a asp-page="/Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-clockwise me-1"></i>بروزرسانی
    </a>
</div>

<!-- Live crawl control -->
<div class="card mb-4" id="crawl-live-panel" dir="rtl">
    <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
        <span class="fw-semibold"><i class="bi bi-activity me-2 text-danger"></i>وضعیت Crawl</span>
        <span class="badge bg-secondary" id="crawl-status-badge">در انتظار</span>
    </div>
    <div class="card-body">
        <div id="crawl-idle-state" class="text-center text-muted py-2">
            <i class="bi bi-pause-circle fs-4 d-block mb-2"></i>
            هیچ Crawl فعالی در حال اجرا نیست
        </div>
        <div id="crawl-active-state" style="display:none">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <div>
                    <div class="fw-semibold" id="crawl-job-name">—</div>
                    <small class="text-muted" id="crawl-started-at">—</small>
                    <div class="small mt-1"><span class="badge bg-secondary" id="crawl-status-label">—</span></div>
                </div>
                <div class="text-end small">
                    <div><span id="crawl-requests">0</span> درخواست Neshan</div>
                    <div><span id="crawl-cells">0</span> سلول پردازش‌شده</div>
                    <div class="text-muted" id="crawl-tasks-planned"></div>
                </div>
            </div>
            <div class="progress rounded-pill mb-2" style="height:12px">
                <div class="progress-bar progress-bar-striped progress-bar-animated bg-danger"
                     id="crawl-progress-bar" style="width:0%"></div>
            </div>
            <div class="row g-2 text-center small mb-2">
                <div class="col-3">
                    <div class="text-muted">سرعت درخواست</div>
                    <div class="fw-bold" id="crawl-req-speed">0 /min</div>
                </div>
                <div class="col-3">
                    <div class="text-muted">سرعت سلول</div>
                    <div class="fw-bold" id="crawl-cell-speed">0 /min</div>
                </div>
                <div class="col-3">
                    <div class="text-muted">POI جدید</div>
                    <div class="fw-bold text-success" id="crawl-new-poi">0</div>
                </div>
                <div class="col-3">
                    <div class="text-muted">POI بروز</div>
                    <div class="fw-bold text-warning" id="crawl-updated-poi">0</div>
                </div>
            </div>
            <div id="crawl-live-error" class="alert alert-danger py-2 px-3 small mb-0" style="display:none" role="alert">
                <i class="bi bi-exclamation-triangle me-1"></i>
                <span id="crawl-live-error-text"></span>
            </div>
        </div>
        <div class="d-flex flex-wrap gap-2 justify-content-center">
            <button type="button" class="btn btn-success btn-sm" id="btn-crawl-start">
                <i class="bi bi-play-fill me-1"></i>شروع
            </button>
            <button type="button" class="btn btn-warning btn-sm" id="btn-crawl-pause" disabled>
                <i class="bi bi-pause-fill me-1"></i>مکث
            </button>
            <button type="button" class="btn btn-primary btn-sm" id="btn-crawl-resume" disabled style="display:none">
                <i class="bi bi-skip-forward-fill me-1"></i>ادامه
            </button>
            <button type="button" class="btn btn-danger btn-sm" id="btn-crawl-stop" disabled>
                <i class="bi bi-stop-fill me-1"></i>توقف
            </button>
        </div>
        <div class="small text-muted text-center mt-2" id="crawl-message"></div>
    </div>
</div>

<!-- Top stat cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="card h-100">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="rounded-circle bg-primary bg-opacity-10 p-2 d-flex">
                        <i class="bi bi-pin-map-fill text-primary"></i>
                    </div>
                    <span class="text-muted small" dir="rtl">کل POI‌ها</span>
                </div>
                <div class="fs-3 fw-bold">@Model.TotalPois.ToString("N0")</div>
                <small class="text-muted">@Model.ActivePois.ToString("N0") فعال</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card h-100">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="rounded-circle bg-success bg-opacity-10 p-2 d-flex">
                        <i class="bi bi-check-circle-fill text-success"></i>
                    </div>
                    <span class="text-muted small" dir="rtl">POI‌های فعال</span>
                </div>
                <div class="fs-3 fw-bold text-success">@Model.ActivePois.ToString("N0")</div>
                @{
                    var activePct = Model.TotalPois > 0
                        ? (int)(Model.ActivePois * 100.0 / Model.TotalPois)
                        : 0;
                }
                <small class="text-muted">@activePct% از کل</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card h-100">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="rounded-circle bg-warning bg-opacity-10 p-2 d-flex">
                        <i class="bi bi-tags-fill text-warning"></i>
                    </div>
                    <span class="text-muted small" dir="rtl">دسته‌بندی‌ها</span>
                </div>
                <div class="fs-3 fw-bold">@Model.TotalCategories</div>
                <small class="text-muted">دسته فعال</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card h-100">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="rounded-circle @(Model.RunningJobs > 0 ? "bg-danger" : "bg-secondary") bg-opacity-10 p-2 d-flex">
                        <i class="bi bi-activity @(Model.RunningJobs > 0 ? "text-danger" : "text-secondary")"></i>
                    </div>
                    <span class="text-muted small" dir="rtl">کارهای در حال اجرا</span>
                </div>
                <div class="fs-3 fw-bold @(Model.RunningJobs > 0 ? "text-danger" : "")" id="stat-running-jobs">@Model.RunningJobs</div>
                <small class="text-muted">
                    <a asp-page="/Jobs/Index" class="text-decoration-none">مشاهده همه</a>
                </small>
            </div>
        </div>
    </div>
</div>

<!-- H3 Coverage + Service Status -->
<div class="row g-3 mb-4">
    <div class="col-md-7">
        <div class="card h-100">
            <div class="card-header bg-transparent fw-semibold d-flex align-items-center gap-2" dir="rtl">
                <i class="bi bi-hexagon-fill text-info"></i>پوشش سلول‌های H3
            </div>
            <div class="card-body">
                <div class="row g-0 text-center mb-3">
                    <div class="col border-end">
                        <div class="text-muted" style="font-size:.75rem" dir="rtl">کل</div>
                        <div class="fw-bold fs-5" id="stat-h3-total">@Model.H3Total.ToString("N0")</div>
                    </div>
                    <div class="col border-end">
                        <div class="text-muted" style="font-size:.75rem">Pending</div>
                        <div class="fw-bold fs-5 text-secondary">@Model.H3Pending.ToString("N0")</div>
                    </div>
                    <div class="col border-end">
                        <div class="text-muted" style="font-size:.75rem">Success</div>
                        <div class="fw-bold fs-5 text-success" id="stat-h3-success">@Model.H3Success.ToString("N0")</div>
                    </div>
                    <div class="col border-end">
                        <div class="text-muted" style="font-size:.75rem">Failed</div>
                        <div class="fw-bold fs-5 text-danger">@Model.H3Failed.ToString("N0")</div>
                    </div>
                    <div class="col">
                        <div class="text-muted" style="font-size:.75rem">Stale</div>
                        <div class="fw-bold fs-5 text-warning">@Model.H3Stale.ToString("N0")</div>
                    </div>
                </div>
                @{
                    var total = Model.H3Total > 0 ? (double)Model.H3Total : 1;
                    var sPct  = (int)(Model.H3Success / total * 100);
                    var fPct  = (int)(Model.H3Failed  / total * 100);
                    var stPct = (int)(Model.H3Stale   / total * 100);
                    var pPct  = Math.Max(0, 100 - sPct - fPct - stPct);
                }
                <div class="progress rounded-pill" style="height:10px" title="H3 coverage">
                    <div class="progress-bar bg-success" style="width:@sPct%" title="Success @sPct%"></div>
                    <div class="progress-bar bg-danger"  style="width:@fPct%" title="Failed @fPct%"></div>
                    <div class="progress-bar bg-warning" style="width:@stPct%" title="Stale @stPct%"></div>
                    <div class="progress-bar bg-secondary opacity-50" style="width:@pPct%" title="Pending @pPct%"></div>
                </div>
                <div class="d-flex gap-3 mt-2" style="font-size:.75rem">
                    <span><span class="badge bg-success">●</span> Success</span>
                    <span><span class="badge bg-danger">●</span> Failed</span>
                    <span><span class="badge bg-warning">●</span> Stale</span>
                    <span><span class="badge bg-secondary">●</span> Pending</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-5">
        <div class="card h-100">
            <div class="card-header bg-transparent fw-semibold d-flex align-items-center gap-2" dir="rtl">
                <i class="bi bi-heart-pulse-fill text-danger"></i>وضعیت سرویس‌ها
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="small"><i class="bi bi-database me-2 text-muted"></i>Database</span>
                        <span class="badge @(Model.DbHealthy ? "bg-success" : "bg-danger")">
                            @(Model.DbHealthy ? "OK" : "DOWN")
                        </span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="small"><i class="bi bi-geo me-2 text-muted"></i>PostGIS</span>
                        <span class="badge @(Model.PostgisHealthy ? "bg-success" : "bg-danger")">
                            @(Model.PostgisHealthy ? "OK" : "DOWN")
                        </span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="small"><i class="bi bi-cpu me-2 text-muted"></i>Worker</span>
                        <span class="badge bg-secondary" id="worker-status-badge">—</span>
                    </li>
                </ul>
                <div class="p-3">
                    @if (Model.LastSuccessfulCrawl.HasValue)
                    {
                        <div class="p-2 bg-success bg-opacity-10 rounded small d-flex align-items-center gap-2" dir="rtl">
                            <i class="bi bi-check2-circle text-success fs-5"></i>
                            <div>
                                <div class="fw-semibold" dir="rtl">آخرین Crawl موفق</div>
                                <div class="text-muted">@Model.LastSuccessfulCrawl.Value.ToString("yyyy-MM-dd HH:mm") UTC</div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="p-2 bg-light rounded small text-muted text-center" dir="rtl">
                            هنوز هیچ Crawl موفقی ثبت نشده
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick links -->
<div class="row g-3">
    <div class="col-12">
        <div class="card">
            <div class="card-body d-flex flex-wrap gap-2" dir="rtl">
                <a asp-page="/Scheduler/Index" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-clock-history me-1"></i>مدیریت زمان‌بندی
                </a>
                <a asp-page="/Crawl/Index" class="btn btn-outline-success btn-sm">
                    <i class="bi bi-play-circle me-1"></i>Crawl دستی (پیشرفته)
                </a>
                <a asp-page="/Jobs/Index" class="btn btn-outline-info btn-sm">
                    <i class="bi bi-list-task me-1"></i>مانیتور کارها
                </a>
                <a asp-page="/Config/Index" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-gear me-1"></i>پیکربندی
                </a>
                <a asp-page="/Coverage/Index" class="btn btn-outline-info btn-sm">
                    <i class="bi bi-grid-3x3-gap me-1"></i>مانیتور پوشش
                </a>
            </div>
        </div>
    </div>
</div>
