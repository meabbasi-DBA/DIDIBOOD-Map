@model Didibood.LocationAccess.Admin.Pages.Jobs.IndexModel
@{
    Layout = null;
}
<div class="table-responsive">
    <table class="table table-hover mb-0 align-middle" style="font-size:.88rem">
        <thead>
            <tr>
                <th>نام کار</th>
                <th>توسط</th>
                <th>وضعیت</th>
                <th>شروع</th>
                <th>مدت</th>
                <th class="text-center">درخواست</th>
                <th class="text-center text-success">جدید</th>
                <th class="text-center text-warning">بروز</th>
                <th class="text-center text-danger">خطا</th>
                <th class="text-center">سلول‌ها</th>
                <th>جریان Grid</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model.Executions)
            {
                var tasksDone = row.CellsProcessed + row.CellsFailed;
                <tr class="@(row.Status is "running" or "queued" ? "table-primary" : "")">
                    <td>
                        <div class="fw-semibold">@row.JobName</div>
                        @if (!string.IsNullOrEmpty(row.LiveError))
                        {
                            <small class="text-danger d-block" title="@row.LiveError">
                                <i class="bi bi-exclamation-triangle me-1"></i>
                                @(row.LiveError.Length > 50 ? row.LiveError[..50] + "…" : row.LiveError)
                            </small>
                        }
                    </td>
                    <td class="small text-muted">@row.TriggeredBy</td>
                    <td>
                        <span class="badge badge-@row.Status d-flex align-items-center gap-1" style="width:fit-content">
                            @if (row.Status is "running" or "queued")
                            {
                                <span class="spinner-grow spinner-grow-sm" role="status" style="width:.4rem;height:.4rem"></span>
                            }
                            @row.Status
                        </span>
                    </td>
                    <td class="small text-muted text-nowrap">
                        @row.StartedAt.ToString("MM-dd HH:mm")
                    </td>
                    <td class="small text-nowrap">
                        @if (row.DurationMs.HasValue)
                        {
                            var ts = TimeSpan.FromMilliseconds(row.DurationMs.Value);
                            if (ts.TotalHours >= 1)
                            {
                                <span>@((int)ts.TotalHours)h @ts.Minutes&#x202F;m</span>
                            }
                            else if (ts.TotalMinutes >= 1)
                            {
                                <span>@((int)ts.TotalMinutes)m @ts.Seconds&#x202F;s</span>
                            }
                            else
                            {
                                <span>@ts.Seconds&#x202F;s</span>
                            }
                        }
                        else if (row.Status is "running" or "queued")
                        {
                            var elapsed = DateTimeOffset.UtcNow - row.StartedAt;
                            <span class="text-primary">@((int)elapsed.TotalMinutes)m @elapsed.Seconds&#x202F;s</span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td class="text-center">@row.RequestCount.ToString("N0")</td>
                    <td class="text-center text-success fw-semibold">@row.NewRecords.ToString("N0")</td>
                    <td class="text-center text-warning fw-semibold">@row.UpdatedRecords.ToString("N0")</td>
                    <td class="text-center text-danger fw-semibold" title="خطای API/سلول@(row.FailedRecords > 0 ? $" — POI: {row.FailedRecords}" : "")">
                        @row.CellsFailed.ToString("N0")
                    </td>
                    <td class="text-center small text-muted">
                        @if (row.TotalTasksPlanned > 0)
                        {
                            <span>@tasksDone.ToString("N0") / @row.TotalTasksPlanned.ToString("N0")</span>
                        }
                        else
                        {
                            <span>@row.CellsProcessed.ToString("N0")</span>
                        }
                    </td>
                    <td class="small">
                        @if (row.CurrentGrid.HasValue)
                        {
                            <div><strong>در حال پردازش:</strong> @row.CurrentGrid.Value</div>
                        }
                        @if (row.QueuedGrids.Count > 0)
                        {
                            <div class="text-muted">صف: @string.Join(", ", row.QueuedGrids.Take(5))@(row.QueuedGrids.Count > 5 ? "…" : "")</div>
                        }
                        @if (row.RecentGrids.Count > 0)
                        {
                            <div class="text-success">اخیر: @string.Join(", ", row.RecentGrids.Take(3))</div>
                        }
                        @if (row.FailedGrids.Count > 0)
                        {
                            <div class="text-danger">ناموفق: @string.Join(", ", row.FailedGrids.Take(3))</div>
                        }
                        @if (!row.CurrentGrid.HasValue && row.QueuedGrids.Count == 0 && row.RecentGrids.Count == 0 && row.FailedGrids.Count == 0)
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                </tr>
            }
            @if (!Model.Executions.Any())
            {
                <tr>
                    <td colspan="11" class="text-center text-muted py-5" dir="rtl">
                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                        هیچ اجرایی ثبت نشده
                        @if (!string.IsNullOrEmpty(Model.StatusFilter))
                        {
                            <span>با وضعیت «@Model.StatusFilter»</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
<div class="px-3 py-2 text-muted small border-top d-flex justify-content-between" dir="rtl">
    <span>@Model.TotalCount رکورد</span>
    <span>صفحه @Model.CurrentPage از @Model.TotalPages</span>
</div>
